# Root / shared — copy to backend/.env and frontend/.env.local as needed

# ─── Local development (docker-compose) ─────────────────────────────────────
DATABASE_URL="postgresql://nexaassist:nexaassist@localhost:5433/nexaassist?schema=public"
REDIS_URL=redis://localhost:6379

# Backend (NestJS)
PORT=4000
NODE_ENV=development
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_MINUTES=15
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
FRONTEND_ORIGIN=http://localhost:3001
REFRESH_TOKEN_TTL_DAYS=7
WORKER_ENABLED=true

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Staging / production (managed hosting) ─────────────────────────────────
# Generate secrets: node scripts/generate-staging-secrets.mjs
# FRONTEND_ORIGIN=https://your-app.vercel.app
# NEXT_PUBLIC_API_URL=https://your-api.onrender.com
# DATABASE_URL=<neon pooled connection string>
# REDIS_URL=<upstash rediss URL>
# CAMPAIGNS_POLLINATIONS_FALLBACK=false

# ─── AI / OpenRouter ────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-flash:free

# ─── NexaAssist chat ─────────────────────────────────────────────────────────
CHAT_AGENT_MODE=primary
CHAT_LOW_CONFIDENCE_THRESHOLD=0.45
CHAT_MAX_AGENT_STEPS=6
CHAT_POLISH_RESPONSES=true
CHAT_MAX_CONTEXT_MESSAGES=20

# ─── Campaigns – Image Generation ───────────────────────────────────────────
CAMPAIGNS_OPENROUTER_IMAGE_MODEL=black-forest-labs/flux.2-klein-4b
TOGETHER_API_KEY=
TOGETHER_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell-Free
CAMPAIGNS_POLLINATIONS_FALLBACK=true

# ─── Object storage (optional; S3-compatible — R2, AWS S3, MinIO) ─────────────
# When set, campaign posters can be uploaded for stable CDN URLs.
# S3_ENDPOINT=
# S3_REGION=auto
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=

# ─── WhatsApp Business API (optional; otherwise simulated) ─────────────────
# WHATSAPP_API_VERSION=v21.0
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=

# ─── Email (optional) ───────────────────────────────────────────────────────
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@yourdomain.com

# ─── Rate limiting ──────────────────────────────────────────────────────────
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120
THROTTLE_AUTH_LIMIT=20
