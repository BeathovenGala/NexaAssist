# Shared example for the whole NexaAssist stack
# Copy backend values to backend/.env and frontend values to frontend/.env.local.

# Local infrastructure
DATABASE_URL=postgresql://nexaassist:nexaassist@localhost:5433/nexaassist?schema=public
REDIS_URL=redis://localhost:6379

# Local origins
FRONTEND_ORIGIN=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:4000

# Backend runtime
NODE_ENV=development
PORT=4000
WORKER_ENABLED=true
DISABLE_PINO_PRETTY=0

# Auth and rate limiting
JWT_ACCESS_SECRET=change-me-to-a-long-random-secret
JWT_ACCESS_EXPIRES_MINUTES=15
BCRYPT_ROUNDS=12
REFRESH_TOKEN_TTL_DAYS=7
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120

# Chat, AI, and campaigns
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-flash:free
OPENROUTER_MAX_RETRIES=2
OPENROUTER_RETRY_BASE_MS=2000
CHAT_LOW_CONFIDENCE_THRESHOLD=0.45
CHAT_MAX_CONTEXT_MESSAGES=8
CAMPAIGNS_OPENROUTER_MODEL=deepseek/deepseek-v4-flash:free
CAMPAIGNS_OPENROUTER_IMAGE_MODEL=black-forest-labs/flux.2-klein-4b
CAMPAIGNS_POLLINATIONS_FALLBACK=true
TOGETHER_API_KEY=
TOGETHER_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell-Free

# Object storage for campaign posters
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_REGION=auto
S3_PUBLIC_BASE_URL=

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@nexaassist.local

# WhatsApp
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v21.0

# Demo seeding
SEED_DEMO_USERS=false
SEED_DEMO_PASSWORD=demo-access-only
SEED_DEMO_ADMIN_EMAIL=tenantadmin.demo@seed.local
SEED_DEMO_TENANT_NAME=Demo Medical Group
SEED_DEMO_TENANT_SLUG=demo-medical-group
SEED_DEMO_TENANT_BUSINESS_TYPE=Healthcare
SEED_DEMO_DOCTOR_EMAIL=dr.rivera.demo@seed.local
SEED_DEMO_INVENTORY_EMAIL=im.chen.demo@seed.local
SEED_DEMO_RECEPTION_EMAIL=rc.morgan.demo@seed.local
SEED_DEMO_STAFF_EMAIL=st.jordan.demo@seed.local
SEED_DEMO_CUSTOMER_TENANT_EMAIL=patient.lee.demo@seed.local
SEED_DEMO_CUSTOMER_SOLO_EMAIL=customer.unaffiliated@seed.local
SEED_DEMO_EXEC_EMAIL=exec.support.demo@seed.local
SEED_SUPER_ADMIN_EMAIL=
SEED_SUPER_ADMIN_PASSWORD=
