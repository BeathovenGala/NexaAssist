generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum RoleName {
  SUPER_ADMIN
  TENANT_ADMIN
  DOCTOR
  INVENTORY_MANAGER
  RECEPTIONIST
  STAFF
  CUSTOMER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  REJECTED
  COMPLETED
  CANCELLED
  RESCHEDULED
  NO_SHOW
}

enum NotificationType {
  APPOINTMENT
  INVENTORY
  REQUEST
  SYSTEM
  SECURITY
  REMINDER
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

enum AppointmentSource {
  DASHBOARD
  PUBLIC_BOOKING
  CHATBOT
  ADMIN_CREATED
}

enum RecurrenceType {
  DAILY
  WEEKLY
  MONTHLY
}

enum SlotType {
  AVAILABLE
  BREAK
  BLOCKED
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InventoryItemStatus {
  ACTIVE
  LOW
  OUT_OF_STOCK
  ARCHIVED
  EXPIRED
  DAMAGED
  RESTRICTED
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
  RETURN
  TRANSFER
  APPROVED_REQUEST
  DAMAGED
  EXPIRED
}

enum ReferenceType {
  APPOINTMENT
  MANUAL
  REQUEST
  TRANSFER
  EXPIRY
}

enum InventoryRequestStatus {
  PENDING
  APPROVED
  REJECTED
  FULFILLED
}

enum RequestPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum InventoryAlertType {
  LOW_STOCK
  OUT_OF_STOCK
  OVERSTOCK
  DAMAGED
  EXPIRING
  HIGH_USAGE
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
}

enum InventoryTransactionType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER
}

enum InventoryTransactionStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model Tenant {
  id               String            @id @default(uuid())
  name             String
  slug             String            @unique
  businessType     String?
  status           TenantStatus      @default(ACTIVE)
  timezone         String?           @default("UTC")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  users            User[]
  userCodeCounters UserCodeCounter[]
  invitations      Invitation[]
  serviceTypes     ServiceType[]
  appointments     Appointment[]
  availabilitySlots AvailabilitySlot[]
  recurringAvailabilityRules RecurringAvailabilityRule[]
  blockedSlots     BlockedSlot[]
  joinRequests       TenantJoinRequest[]
  inventoryCategories InventoryCategory[]
  inventoryItems      InventoryItem[]
  stockMovements      StockMovement[]
  inventoryRequests   InventoryRequest[]
  inventoryAlerts     InventoryAlert[]
  inventoryTransactions InventoryTransaction[]
  notifications         Notification[]
}

model Invitation {
  id          String       @id @default(uuid())
  tenantId  String
  email       String?
  phone       String?
  roleId      String
  tokenHash   String       @unique
  status      InviteStatus @default(PENDING)
  expiresAt   DateTime
  createdById String
  acceptedAt  DateTime?
  createdAt   DateTime     @default(now())
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role        Role         @relation(fields: [roleId], references: [id], onDelete: Restrict)
  createdBy   User         @relation("InvitationCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([status])
}

model User {
  id            String         @id @default(uuid())
  userCode      String         @unique
  tenantId      String?
  tenant        Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email         String         @unique
  passwordHash  String
  firstName     String
  lastName      String?
  phone         String?
  status        UserStatus     @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  userRoles            UserRole[]
  refreshTokens        RefreshToken[]
  invitationsCreated   Invitation[] @relation("InvitationCreatedBy")
  appointmentsAsCustomer Appointment[] @relation("AppointmentCustomer")
  appointmentsAsStaff    Appointment[] @relation("AppointmentStaff")
  appointmentsCreated    Appointment[] @relation("AppointmentCreatedBy")
  availabilitySlots    AvailabilitySlot[]
  recurringAvailabilityRules RecurringAvailabilityRule[]
  blockedSlots           BlockedSlot[]
  appointmentHistory     AppointmentHistory[]
  appointmentNotes       AppointmentNote[]
  joinRequests           TenantJoinRequest[]
  inventoryItemsCreated  InventoryItem[]      @relation("InventoryItemCreatedBy")
  stockMovementsPerformed StockMovement[]
  inventoryRequestsCreated InventoryRequest[] @relation("InventoryRequestRequestedBy")
  inventoryRequestsApproved InventoryRequest[] @relation("InventoryRequestApprovedBy")
  inventoryTransactionsPerformed InventoryTransaction[]
  notifications                  Notification[]

  @@index([tenantId])
  @@index([email])
}

model Notification {
  id        String               @id @default(uuid())
  tenantId  String
  tenant    Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  priority  NotificationPriority @default(NORMAL)
  status    NotificationStatus   @default(UNREAD)
  actionUrl String?
  metadata  Json?
  dedupeKey String?
  readAt    DateTime?
  createdAt DateTime             @default(now())

  @@unique([tenantId, userId, dedupeKey])
  @@index([tenantId, userId, status, createdAt])
  @@index([tenantId, userId, createdAt])
}

model NotificationDelivery {
  id        String   @id @default(uuid())
  tenantId  String
  dedupeKey String
  channel   String
  sentAt    DateTime @default(now())

  @@unique([tenantId, dedupeKey, channel])
  @@index([tenantId])
}

model TenantJoinRequest {
  id        String             @id @default(uuid())
  tenantId  String
  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    JoinRequestStatus  @default(PENDING)
  note      String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([tenantId])
  @@index([userId])
  @@index([tenantId, status])
}

model ServiceType {
  id               String   @id @default(uuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name             String
  durationMinutes  Int
  colorCode        String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  appointments     Appointment[]

  @@index([tenantId])
  @@index([tenantId, isActive])
}

model Appointment {
  id                   String             @id @default(uuid())
  tenantId             String
  tenant               Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointmentCode      String
  customerId           String
  customer             User               @relation("AppointmentCustomer", fields: [customerId], references: [id], onDelete: Restrict)
  assignedStaffId      String
  assignedStaff        User               @relation("AppointmentStaff", fields: [assignedStaffId], references: [id], onDelete: Restrict)
  createdById          String
  createdBy            User               @relation("AppointmentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  serviceTypeId        String?
  serviceType          ServiceType?       @relation(fields: [serviceTypeId], references: [id], onDelete: SetNull)
  title                String
  description          String?
  startTime            DateTime
  endTime              DateTime
  timezone             String             @default("UTC")
  status               AppointmentStatus  @default(PENDING)
  source               AppointmentSource  @default(DASHBOARD)
  notes                String?
  cancellationReason   String?
  rescheduledFromId    String?
  rescheduledFrom      Appointment?       @relation("AppointmentReschedule", fields: [rescheduledFromId], references: [id], onDelete: SetNull)
  rescheduledTo        Appointment[]      @relation("AppointmentReschedule")
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  history              AppointmentHistory[]
  appointmentNotes     AppointmentNote[]
  reminders            AppointmentReminder[]

  @@unique([tenantId, appointmentCode])
  @@index([tenantId])
  @@index([tenantId, assignedStaffId, startTime, endTime])
  @@index([tenantId, customerId])
  @@index([tenantId, status])
}

model AvailabilitySlot {
  id                 String    @id @default(uuid())
  tenantId           String
  tenant             Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staffId            String
  staff              User      @relation(fields: [staffId], references: [id], onDelete: Cascade)
  startTime          DateTime
  endTime            DateTime
  slotType           SlotType  @default(AVAILABLE)
  isAvailable        Boolean   @default(true)
  recurrenceGroupId  String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([tenantId, staffId])
  @@index([tenantId, staffId, startTime, endTime])
}

model RecurringAvailabilityRule {
  id              String         @id @default(uuid())
  tenantId        String
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staffId         String
  staff           User           @relation(fields: [staffId], references: [id], onDelete: Cascade)
  dayOfWeek       Int
  startHour       Int
  startMinute     Int            @default(0)
  endHour         Int
  endMinute       Int            @default(0)
  recurrenceType  RecurrenceType @default(WEEKLY)
  effectiveFrom   DateTime
  effectiveUntil  DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([tenantId, staffId])
}

model BlockedSlot {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staffId     String
  staff       User     @relation(fields: [staffId], references: [id], onDelete: Cascade)
  reason      String?
  blockedFrom DateTime
  blockedTo   DateTime
  createdAt   DateTime @default(now())

  @@index([tenantId, staffId])
  @@index([tenantId, staffId, blockedFrom, blockedTo])
}

model AppointmentHistory {
  id             String   @id @default(uuid())
  appointmentId  String
  appointment    Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  actionType     String
  previousValue  Json?
  newValue       Json?
  performedById  String
  performedBy    User     @relation(fields: [performedById], references: [id], onDelete: Restrict)
  createdAt      DateTime @default(now())

  @@index([appointmentId])
  @@index([createdAt])
}

model AppointmentNote {
  id            String      @id @default(uuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  tenantId      String
  content       String
  createdById   String
  createdBy     User        @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt     DateTime    @default(now())

  @@index([appointmentId])
  @@index([tenantId])
}

model AppointmentReminder {
  id            String      @id @default(uuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  scheduledAt   DateTime
  channel       String?
  sent          Boolean     @default(false)
  createdAt     DateTime    @default(now())

  @@index([appointmentId])
  @@index([scheduledAt, sent])
}

model Role {
  id              String           @id @default(uuid())
  name            RoleName         @unique
  description     String?
  rolePermissions RolePermission[]
  userRoles       UserRole[]
  invitations     Invitation[]
}

model Permission {
  id              String           @id @default(uuid())
  code            String           @unique
  module          String?
  description     String?
  rolePermissions RolePermission[]

  @@index([module])
}

model RolePermission {
  roleId         String
  permissionId   String
  role           Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission     Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRole {
  userId String
  roleId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

/// Per-scope (tenant slug or PLATFORM) sequence for readable user codes (TA-SLUG-001, DR-SLUG-002, …).
model UserCodeCounter {
  id       String  @id @default(uuid())
  scopeKey String
  prefix   String
  lastSeq  Int     @default(0)
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([scopeKey, prefix])
}

model InventoryCategory {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  items       InventoryItem[]

  @@index([tenantId])
  @@index([tenantId, deletedAt])
}

model InventoryItem {
  id                 String               @id @default(uuid())
  tenantId           String
  tenant             Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryId         String?
  category           InventoryCategory?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  name               String
  sku                String
  description        String?
  unit               String
  barcode            String?
  locationId         String?
  quantity           Int                  @default(0)
  reservedQuantity   Int                  @default(0)
  minimumThreshold   Int                  @default(0)
  maximumThreshold   Int?
  status             InventoryItemStatus  @default(ACTIVE)
  isActive           Boolean              @default(true)
  createdById        String
  createdBy          User                 @relation("InventoryItemCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  deletedAt          DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  stockMovements     StockMovement[]
  inventoryRequests  InventoryRequest[]
  inventoryAlerts    InventoryAlert[]
  transactionItems   InventoryTransactionItem[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@index([tenantId, status])
  @@index([tenantId, categoryId])
}

model StockMovement {
  id               String         @id @default(uuid())
  tenantId         String
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  itemId           String
  item             InventoryItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  movementType     MovementType
  quantity         Int
  previousQuantity Int
  newQuantity      Int
  reason           String?
  referenceType    ReferenceType?
  referenceId      String?
  locationId       String?
  performedById    String
  performedBy      User           @relation(fields: [performedById], references: [id], onDelete: Restrict)
  createdAt        DateTime       @default(now())

  @@index([tenantId])
  @@index([tenantId, itemId])
  @@index([tenantId, createdAt])
  @@index([itemId, createdAt])
}

model InventoryRequest {
  id                  String                 @id @default(uuid())
  tenantId            String
  tenant              Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  itemId              String
  item                InventoryItem          @relation(fields: [itemId], references: [id], onDelete: Cascade)
  requestedById       String
  requestedBy         User                   @relation("InventoryRequestRequestedBy", fields: [requestedById], references: [id], onDelete: Restrict)
  quantityRequested   Int
  approvedQuantity    Int?
  fulfilledQuantity   Int                    @default(0)
  priority            RequestPriority        @default(NORMAL)
  reason              String?
  status              InventoryRequestStatus @default(PENDING)
  managerNotes        String?
  approvedById        String?
  approvedBy          User?                  @relation("InventoryRequestApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt          DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([itemId])
}

model InventoryAlert {
  id        String             @id @default(uuid())
  tenantId  String
  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  itemId    String
  item      InventoryItem      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  type      InventoryAlertType
  severity  AlertSeverity
  status    AlertStatus        @default(ACTIVE)
  message   String
  isRead    Boolean            @default(false)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([itemId])
}

model InventoryTransaction {
  id             String                     @id @default(uuid())
  tenantId       String
  tenant         Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type           InventoryTransactionType
  status         InventoryTransactionStatus @default(PENDING)
  notes          String?
  locationId     String?
  performedById  String
  performedBy    User                       @relation(fields: [performedById], references: [id], onDelete: Restrict)
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  items          InventoryTransactionItem[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
}

model InventoryTransactionItem {
  id            String               @id @default(uuid())
  transactionId String
  transaction   InventoryTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  itemId        String
  item          InventoryItem        @relation(fields: [itemId], references: [id], onDelete: Restrict)
  quantity      Int

  @@index([transactionId])
  @@index([itemId])
}
